[user]
	name = Laurent Quillerou
	email = laurent.quillerou@gmail.com
[core]
	editor = vim
	excludesfile = ${HOME}/.gitignore
[color]
	branch = auto
	diff = auto
	interactive = auto
	status = auto
	ui = true
[alias]
	a = add
	aa = add --all
	b = branch
	ba = branch -a
	c = clone
	ci = commit -a
	cim = commit -a -m
	co = checkout
	com = checkout master
	d = diff
	f = fetch
	l = log
	lg = log --graph --pretty=oneline
	lga = log --graph --decorate --all
	ls = log --stat
	m = merge
	p = pull
	ph = push
	r = remote
	rb = rebase
	rbi = rebase -i
	st = status
	sta = stash
	t = tag
	unstage = reset HEAD
	wup = log -p
[inspector]
	file-types = java,c,cpp,h,hpp,py,glsl,rb,js,sql,xml,md,txt,csv,lock,example,json,scss,php,yml,css
	list-file-types = true
	metrics = true
	responsibilities = true
	timeline = true
