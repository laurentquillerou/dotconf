[user]
  name = Laurent Quillerou
  email = laurent.quillerou@gmail.com

[includeIf "gitdir:~/work/"]
  path = ~/work/.gitconfig

[alias]
  a = add
  aa = add --all
  b = branch
  ba = branch -a
  c = clone
  ci = commit -a
  cim = commit -a -m
  co = checkout
  com = checkout main
  coma = checkout master
  d = diff
  f = fetch -p
  fix = rbi HEAD~2
  fixb = rbi origin
  hist = log --pretty=format:'%h %ad | %s%d [%an]' --graph --date=short
  l = log
  lg = log --graph --pretty=oneline --abbrev-commit
  lga = log --graph --decorate --all --abbrev-commit
  lgb = log --graph --pretty=oneline origin/main^..HEAD --abbrev-commit
  lgbm = log --graph --pretty=oneline origin/master^..HEAD --abbrev-commit
  ls = log --stat --abbrev-commit
  m = merge
  p = pull
  ph = push
  r = remote
  rb = rebase
  rbi = rebase -i
  rbm = rebase main
  rbma = rebase master
  rpsh = rev-parse --short HEAD
  st = status
  sta = stash
  t = tag
  unstage = reset HEAD
  wup = log -p

[branch]
  sort = -committerdate

[color]
  branch = auto
  diff = auto
  interactive = auto
  status = auto
  ui = true

[column]
  ui = auto

[commit]
  verbose = true

[core]
  editor = vim
  excludesfile = ${HOME}/.gitignore
  autocrlf = input

[diff]
  #algorithm = histogram
  colorMovedWS = ignore-all-space
  colorMoved = zebra # plain
  mnemonicPrefix = true
  renames = true

[fetch]
  all = true
  prune = true
  pruneTags = true

[init]
  defaultBranch = main

[inspector]
  file-types = java,c,cpp,h,hpp,py,glsl,rb,js,sql,xml,md,txt,csv,lock,example,json,scss,php,yml,css
  list-file-types = true
  metrics = true
  responsibilities = true
  timeline = true

[pull]
  rebase = true

[push]
  autoSetupRemote = true
  default = simple
  followTags = true

[rebase]
  autoSquash = true
  autoStash = true
  updateRefs = true

[tag]
  sort = version:refname
